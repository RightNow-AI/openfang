# OpenFang systemd environment file
# Install to /etc/openfang/env with mode 0640 and group openfang.

# Keep this aligned with the systemd unit baseline.
OPENFANG_HOME=/var/lib/openfang

# Required for strict production probes and protected endpoints.
# Generate with: openssl rand -hex 32
OPENFANG_API_KEY=change-me

# Optional operator defaults.
OPENFANG_KEEP_BACKUPS=7
RUST_LOG=openfang=info,warn

# Set the provider key that matches config.toml's [default_model].api_key_env.
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
