# OpenFang Agent OS -- example configuration
# Copy to ~/.openfang/config.toml and customize.

# HTTP API settings
api_listen = "127.0.0.1:4200"
# api_key = ""  # Prefer OPENFANG_API_KEY in production
# network_enabled = false
# usage_footer = "full"

[default_model]
provider = "anthropic"
model = "claude-sonnet-4-20250514"
api_key_env = "ANTHROPIC_API_KEY"
# base_url = "https://api.anthropic.com"

[memory]
decay_rate = 0.05
# sqlite_path = "~/.openfang/data/openfang.db"

[network]
listen_addresses = ["/ip4/0.0.0.0/tcp/0"]
# bootstrap_peers = []
# mdns_enabled = true
# max_peers = 50
# shared_secret = ""

[web]
search_provider = "auto"
cache_ttl_minutes = 15

[browser]
headless = true

[reload]
mode = "hybrid"
debounce_ms = 500

[budget]
alert_threshold = 0.8

[auth]
enabled = false
username = "admin"
# Generate with: openfang security hash-password
# When auth.enabled = true, password_hash must be a valid Argon2id PHC string.
# A 64-character legacy SHA-256 hex digest is also accepted for compatibility.
password_hash = ""

# Channel adapters
[channels.telegram]
bot_token_env = "TELEGRAM_BOT_TOKEN"
allowed_users = []
poll_interval_secs = 1
# download_enabled = false
# use_local_api = false
# api_url = "http://127.0.0.1:8081"
# telegram_api_id = "123456"
# telegram_api_hash_env = "TELEGRAM_API_HASH"
# auto_start_local_api = false
# local_api_port = 8081

# IMPORTANT: Telegram Group Configuration
# For the bot to work in groups, you MUST configure BOTH layers:
#
# 1. Telegram Layer (BotFather settings):
#    - Open @BotFather in Telegram
#    - Send /mybots → Select your bot → Bot Settings → Group Privacy
#    - Choose "Turn off" to allow the bot to receive group messages
#    - Without this, the bot will ONLY receive /commands, NOT @mentions
#
# 2. OpenFang Layer (config below):
#    - Use [channels.telegram.overrides] to control bot behavior
#    - group_policy options:
#      * "ignore" - Don't respond to any group messages
#      * "commands_only" - Only respond to /commands
#      * "mention_only" - Only respond when @mentioned (RECOMMENDED)
#      * "all" - Respond to all group messages (not recommended)
#
# Recommended setup for groups:
# - BotFather: Group Privacy = OFF
# - Config: group_policy = "mention_only"
# Result: Bot receives all messages but only responds to @mentions
#
# [channels.telegram.overrides]
# dm_policy = "respond"      # How to handle direct messages: "ignore" | "allowed_only" | "respond"
# group_policy = "mention_only"  # How to handle group messages: "ignore" | "commands_only" | "mention_only" | "all"

[channels.discord]
bot_token_env = "DISCORD_BOT_TOKEN"
allowed_guilds = []

[channels.slack]
bot_token_env = "SLACK_BOT_TOKEN"
app_token_env = "SLACK_APP_TOKEN"

# MCP server connections
[[mcp_servers]]
name = "filesystem"
timeout_secs = 30
env = []

[mcp_servers.transport]
type = "stdio"
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
